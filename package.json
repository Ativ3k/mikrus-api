{
	"name": "mikrus-api",
	"version": "1.0.2",
	"description": "Lightweight API wrapper for mikr.us",
	"keywords": [
		"mikrus-api",
		"mikrus-wrapper",
		"mikrus-sdk"
	],
	"author": "Ativ3k",
	"license": "MIT",
	"homepage": "https://github.com/Ativ3k/mikrus-api",
	"repository": {
		"type": "git",
		"url": "https://github.com/Ativ3k/mikrus-api.git"
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build:js": "bun build src/index.ts --outdir dist --format esm && bun build src/index.ts --outfile dist/index.cjs --format cjs",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"build": "bun run build:js && bun run build:types",
		"prepublish": "bun run build"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"typescript": "^5.9.3"
	}
}
