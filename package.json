{
	"name": "mikrus-api",
	"version": "0.8.0",
	"description": "Zero dependency API wrapper for mikr.us API",
	"keywords": [
		"mikrus-api",
		"mikrus-wrapper",
		"mikrus-sdk"
	],
	"license": "MIT",
	"homepage": "https://github.com/Ativ3k/mikrus-api",
	"repository": {
		"type": "git",
		"url": "https://github.com/Ativ3k/mikrus-api.git"
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=20"
	},
	"devDependencies": {
		"@types/node": "^25.4.0"
	}
}
